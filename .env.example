# Public — bundled into the client. Safe to expose; access enforced by RLS.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never bundled. Used by migration scripts / future server jobs.
# Keep this in `~/.claude-secrets/slothcv.env` locally; in CI/CF Pages set via
# `wrangler pages secret put SUPABASE_SERVICE_ROLE_KEY`.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudflare Turnstile (bot / captcha protection on /login + /signup).
# Public sitekey only — the secret key lives in Supabase Auth settings.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-sitekey

# ── Site / SEO ────────────────────────────────────────────────────────
# THE DOMAIN SWITCH. Canonical absolute base URL, no trailing slash. Drives
# the metadata canonical, OpenGraph/Twitter tags, sitemap.xml, robots.txt
# host and JSON-LD. When you buy the domain, set this ONE value to it (here
# AND in the Cloudflare Pages project env), then rebuild + redeploy — every
# SEO surface updates from it, and indexing flips on automatically (preview
# hosts like *.pages.dev are auto-noindexed). Unset → falls back to
# https://slothcv.pages.dev.
NEXT_PUBLIC_SITE_URL=https://slothcv.philipsloth.com

# Google Search Console verification token — the content="..." value from
# GSC's "HTML tag" verification method. Renders a verification <meta> only
# when set. Leave blank until you verify the bought domain in GSC.
NEXT_PUBLIC_GSC_VERIFICATION=
