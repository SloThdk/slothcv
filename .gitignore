# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# cloudflare wrangler
.wrangler/
.dev.vars

# supabase CLI cache (version stamp etc)
supabase/.temp/

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE / agent tooling — installed locally per developer.
#
# `.mcp.json` is gitignored because the Supabase MCP URL embeds the
# project_ref of the maintainer's own Supabase project — shipping the real
# value in a public repo would let attackers more easily pinpoint the
# deployment for targeted RLS / rate-limit probing. Contributors copy
# `.mcp.example.json` to `.mcp.json` and fill in their own ref.
#
# The `skills-lock.json` manifest IS tracked; only the resolved skill
# content + per-IDE views stay local so the repo isn't bloated with
# multiple copies of the same docs.
.mcp.json
.agents/
.claude/
.windsurf/
skills/

# Lockfiles — bun is the canonical package manager (see start_local_server.bat
# and the bun.lock at repo root). package-lock.json is auto-generated by
# anyone who runs `npm install` against the same package.json and should
# never be committed alongside bun.lock — that ambiguity confuses CI and
# contributors.
package-lock.json
yarn.lock
pnpm-lock.yaml
