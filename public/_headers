# Cloudflare Pages headers config for slothcv.pages.dev.
#
# This file applies HTTP headers to every response Cloudflare Pages emits.
# Pages has no per-request middleware on a static export, so this file is
# the only place to control caching + security headers — getting it right
# matters because there's no second chance later in the request lifecycle.
#
# ─── Caching ──────────────────────────────────────────────────────────
# By default Pages serves HTML with `Cache-Control: public, max-age=0,
# must-revalidate` — browsers DO store a cached copy and merely revalidate
# before reuse. Some real-world conditions (iOS Safari with the page open
# in a tab, browsers under aggressive battery / data-saving) skip the
# revalidation or accept a stale 304, and the user sees an old layout for
# hours after a fresh deploy. Setting `no-store` on HTML guarantees no
# browser ever serves a cached copy without round-tripping. CSS / JS get
# `immutable` because Next.js hashes their filenames in the build output.
#
# ─── Security headers ─────────────────────────────────────────────────
# The CSP allows Supabase (REST + Realtime + Storage) for runtime auth
# and CV persistence, plus the same-origin self for everything else. No
# Stripe, no Turnstile, no third-party analytics — slothcv has no payment
# flow and no consented tracking, so the policy is intentionally narrower
# than the philipsloth-portfolio CSP.
#
# `'unsafe-inline'` on `script-src` is required because Next.js's
# static-export hydration emits inline `<script>` tags without a nonce
# (CF Pages has no per-request middleware to mint one). The threat
# model accepts this: SlothCV's user input is a structured CV form,
# never raw HTML or markdown, so the application surface that could
# inject a malicious inline script doesn't exist. Worker-src allows
# blob: because the PDF render uses a web worker spawned from a Blob URL.
#
# `'unsafe-eval'` is also accepted because Zod v4's optimised parser
# compiles validation schemas via `new Function(...)` at runtime
# (verified in chunk dump 2026-05-16). Without it the library falls
# back to a slower interpreted path AND emits a console error on every
# page load — security posture is functionally identical to the
# inline-script acceptance above (both depend on the same "no
# user-supplied script content" property), and silencing the error
# stops it from drowning real diagnostics in the browser console.
#
# `https://challenges.cloudflare.com` is allowed in script-src,
# connect-src, and frame-src because Cloudflare Turnstile (anti-bot
# captcha on /login + /signup) loads its widget script + makes API
# calls from there + renders an iframe for the challenge UI. Without
# these three allowances the Turnstile widget silently fails to
# render, the captcha token never arrives, and the Send Link button
# stays disabled forever — Philip's bug report 2026-05-16. Domain is
# Cloudflare's first-party CAPTCHA host; same trust level as our
# own Supabase host already allowed in connect-src.
#
# `Cross-Origin-Opener-Policy` is set to `same-origin-allow-popups` (not
# the stricter `same-origin`) because the Google OAuth flow opens a
# pop-up and the strict variant breaks the OAuth callback's
# `window.opener` reference. Auth callbacks in slothcv land on the same
# origin so the popups variant is the right balance.

# All HTML — never cache, full security headers.
# `no-store` is the operative directive (never write a copy to any cache);
# `no-cache, must-revalidate, max-age=0` are the belt-and-suspenders companions
# for intermediaries that parse the set inconsistently. `public` was dropped —
# it contradicts `no-store` and some parsers honour the wrong half. Clients
# that ignore this anyway (bfcache, data-saver, a stale pre-fix copy) are
# caught at runtime by VersionGuard (src/components/version-guard.tsx).
/*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://challenges.cloudflare.com; worker-src 'self' blob:; frame-src 'self' https://challenges.cloudflare.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: same-origin

# Hashed Next.js bundles — cache forever; the hash changes on rebuild.
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Public static assets — 30-day cache with revalidation.
#
# Image filenames are renamed (foo.png -> foo-v2.png) when content
# changes rather than mutating in place, so a long TTL is safe and
# saves the revalidation round-trip on every repeat visit. The .avif
# and .webp variants emitted by scripts/optimize-images.mjs inherit
# the same TTL — sharp regenerates them when the source mtime moves,
# so they share the source's effective version.
/icons/*
  Cache-Control: public, max-age=2592000, must-revalidate

/images/*
  Cache-Control: public, max-age=2592000, must-revalidate

# === Robotted-out auth surface ===
# Auth callbacks, dashboard, and editor are not crawlable. The HTTP
# header below is a defense-in-depth third layer alongside the meta
# robots tag in the HTML and the robots.txt disallow rules — older
# crawlers honour HTTP headers but skip body parsing, so the header
# is the most reliable signal that reaches archival bots.
/auth/*
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet

/dashboard
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet

/dashboard/*
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet

/editor
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet

/editor/*
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet

/new
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet

/new/*
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet

/account
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet

/account/*
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet

# Auth utility pages — left crawlable (so a stray inbound link resolves) but
# marked noindex: a thin login / signup / password form has no search value
# and shouldn't compete with the landing page. robots.ts deliberately does
# NOT Disallow these, so crawlers fetch them, see noindex, and drop them
# cleanly instead of leaving a bare URL in the index.
/login
  X-Robots-Tag: noindex, nofollow
/login/*
  X-Robots-Tag: noindex, nofollow
/signup
  X-Robots-Tag: noindex, nofollow
/signup/*
  X-Robots-Tag: noindex, nofollow
/forgot-password
  X-Robots-Tag: noindex, nofollow
/forgot-password/*
  X-Robots-Tag: noindex, nofollow
/reset-password
  X-Robots-Tag: noindex, nofollow
/reset-password/*
  X-Robots-Tag: noindex, nofollow

# /debug-templates is a developer-only template-render audit page (see
# the docstring in src/app/debug-templates/page.tsx) that should not
# appear in search results or any AI training corpus. It currently
# ships in the build because it doubles as a quick visual QA tool;
# noindex headers + the matching robots.txt disallow keep it out of
# crawler indexes regardless.
/debug-templates
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet

/debug-templates/*
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet
